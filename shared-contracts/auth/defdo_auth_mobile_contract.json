{
  "contract": "defdo_auth_mobile",
  "version": "2026-06-09.1",
  "oracle": "defdo_auth_client",
  "runtime_mobile_sdk": false,
  "flow": "authorization_code_pkce",
  "required_authorization_params": [
    "response_type",
    "client_id",
    "redirect_uri",
    "scope",
    "state",
    "code_challenge",
    "code_challenge_method"
  ],
  "code_challenge_method": "S256",
  "optional_authorization_params": ["nonce"],
  "logout": {
    "clear_local_session_when_revoke_fails": true
  },
  "refresh": {
    "replace_refresh_token_when_returned": true,
    "invalid_grant_requires_login": true
  }
}
