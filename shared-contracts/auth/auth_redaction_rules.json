{
  "redact_keys": [
    "access_token",
    "refresh_token",
    "id_token",
    "code",
    "code_verifier",
    "claims"
  ],
  "redact_query_params": [
    "access_token",
    "refresh_token",
    "id_token",
    "code",
    "code_verifier"
  ],
  "redact_headers": [
    "authorization",
    "set-cookie"
  ],
  "redact_callback_url": {
    "description": "Raw callback URLs must have sensitive query params redacted",
    "sensitive_params": [
      "code",
      "state",
      "id_token",
      "access_token"
    ]
  },
  "redact_claims_values": {
    "description": "claims may be string, object, or array and all forms must be redacted",
    "forms": ["string", "object", "array"]
  },
  "replacement": "[REDACTED]"
}
