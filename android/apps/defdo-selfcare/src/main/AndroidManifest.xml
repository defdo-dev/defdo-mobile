<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET" />

    <application
        android:allowBackup="false"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.DefdoSelfCare"
        android:usesCleartextTraffic="true">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTask">

            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>

            <!-- App Links / HTTPS callback. This is the production target.
                 android:autoVerify="true" triggers domain verification on
                 Android 6+. The dev assetlinks.json must be deployed on the
                 redirect host before HTTPS callbacks work. -->
            <intent-filter android:autoVerify="true">
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="${defdoAuthRedirectScheme}"
                    android:host="${defdoAuthRedirectHost}"
                    android:pathPrefix="${defdoAuthRedirectPathPrefix}" />
            </intent-filter>

            <!-- Dev-only custom scheme fallback for local OAuth smoke when
                 App Links verification is not yet deployed. Do NOT use this in
                 production builds; production must rely on verified App Links. -->
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="defdo.selfcare.dev"
                    android:host="oauth.callback"
                    android:pathPrefix="/" />
            </intent-filter>
        </activity>
    </application>
</manifest>
